<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.devslab.examples.easypaging.report.ReportMapper">

    <!--
        Plain SELECT — no LIMIT, no OFFSET, no COUNT.
        @AutoPaginate on the controller injects pagination at runtime via
        PageHelper, and the aspect adds ORDER BY based on the request's ?sort= param.
    -->
    <select id="findAll" resultType="kr.devslab.examples.easypaging.report.Report">
        SELECT id, title, created_at AS createdAt
        FROM reports
    </select>

</mapper>
